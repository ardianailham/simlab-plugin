<?xml version="1.0"?>
<ruleset name="PHPCompatibilityCheck">
    <description>Check compatibility with PHP versions 7.4-8.3</description>

    <!-- Path to check -->
    <file>.</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- Configure the PHPCompatibility rule -->
    <rule ref="PHPCompatibility"/>

    <!-- Set the target PHP versions -->
    <config name="testVersion" value="7.4-8.3"/>

    <!-- Display progress and use colors -->
    <arg value="p"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
</ruleset>
